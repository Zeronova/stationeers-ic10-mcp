{
  "l": {
    "syntax": "l r? d? logicType",
    "desc": "Load value from device register to internal register",
    "cat": "Data Transfer",
    "example": "l r0 d0 Pressure"
  },
  "s": {
    "syntax": "s d? logicType r?",
    "desc": "Set value from internal register to device register",
    "cat": "Data Transfer",
    "example": "s d0 On r0"
  },
  "move": {
    "syntax": "move r? (r?|num)",
    "desc": "Copy a value into a register (constant or register-to-register)",
    "cat": "Data Transfer",
    "example": "move r0 10"
  },
  "lr": {
    "syntax": "lr r? d? logicType",
    "desc": "Load from device register, use with indirect/circular references",
    "cat": "Data Transfer",
    "example": ""
  },
  "ls": {
    "syntax": "ls d? logicType r?",
    "desc": "Set value to device register, use with indirect/circular references",
    "cat": "Data Transfer",
    "example": ""
  },
  "lb": {
    "syntax": "lb r? deviceHash logicType batchMode",
    "desc": "Batch load from ALL devices matching deviceHash. batchMode: 0=Average, 1=Sum, 2=Minimum, 3=Maximum",
    "cat": "Batch IO",
    "example": "lb r0 HASH(\"StructureGasSensor\") Temperature Average"
  },
  "lbs": {
    "syntax": "lbs r? deviceHash logicType batchMode",
    "desc": "Batch load sorted results from matching devices",
    "cat": "Batch IO",
    "example": ""
  },
  "lbn": {
    "syntax": "lbn r? deviceHash nameHash logicType batchMode",
    "desc": "Batch load from devices matching deviceHash AND nameHash",
    "cat": "Batch IO",
    "example": "lbn r0 HASH(\"StructureGasSensor\") HASH(\"Sensor 1\") Temperature Average"
  },
  "lbns": {
    "syntax": "lbns r? deviceHash nameHash logicType batchMode",
    "desc": "Batch load sorted from devices matching device AND name hash",
    "cat": "Batch IO",
    "example": ""
  },
  "sb": {
    "syntax": "sb deviceHash logicType r?",
    "desc": "Batch write to ALL devices matching deviceHash",
    "cat": "Batch IO",
    "example": "sb HASH(\"StructureDoor\") Open r0"
  },
  "sbs": {
    "syntax": "sbs deviceHash logicType r?",
    "desc": "Batch write sorted to all devices matching hash",
    "cat": "Batch IO",
    "example": ""
  },
  "sbn": {
    "syntax": "sbn deviceHash nameHash logicType r?",
    "desc": "Batch write to devices matching device AND name hash",
    "cat": "Batch IO",
    "example": "sbn HASH(\"StructureDoor\") HASH(\"Airlock\") Open r0"
  },
  "add": { "syntax": "add r? a b", "desc": "r? = a + b", "cat": "Arithmetic", "example": "add r1 r0 3" },
  "sub": { "syntax": "sub r? a b", "desc": "r? = a - b", "cat": "Arithmetic", "example": "sub r1 r0 5" },
  "mul": { "syntax": "mul r? a b", "desc": "r? = a * b", "cat": "Arithmetic", "example": "mul r2 r0 r1" },
  "div": { "syntax": "div r? a b", "desc": "r? = a / b", "cat": "Arithmetic", "example": "div r3 r0 100" },
  "mod": { "syntax": "mod r? a b", "desc": "r? = a % b (modulo)", "cat": "Arithmetic", "example": "mod r1 r0 10" },
  "abs": { "syntax": "abs r? a", "desc": "r? = |a| (absolute value)", "cat": "Arithmetic", "example": "abs r0 r1" },
  "neg": { "syntax": "neg r? a", "desc": "r? = -a (negation)", "cat": "Arithmetic", "example": "" },
  "min": { "syntax": "min r? a b", "desc": "r? = min(a, b)", "cat": "Arithmetic", "example": "min r0 r1 r2" },
  "max": { "syntax": "max r? a b", "desc": "r? = max(a, b)", "cat": "Arithmetic", "example": "max r0 r1 r2" },
  "sqrt": { "syntax": "sqrt r? a", "desc": "r? = sqrt(a)", "cat": "Math", "example": "sqrt r0 r1" },
  "exp": { "syntax": "exp r? a", "desc": "r? = e^a", "cat": "Math", "example": "" },
  "log": { "syntax": "log r? a", "desc": "r? = ln(a)", "cat": "Math", "example": "" },
  "round": { "syntax": "round r? a", "desc": "r? = round to nearest int", "cat": "Math", "example": "" },
  "floor": { "syntax": "floor r? a", "desc": "r? = floor(a)", "cat": "Math", "example": "" },
  "ceil": { "syntax": "ceil r? a", "desc": "r? = ceil(a)", "cat": "Math", "example": "" },
  "trunc": { "syntax": "trunc r? a", "desc": "r? = truncate decimals", "cat": "Math", "example": "" },
  "rand": { "syntax": "rand r? a", "desc": "r? = random 0..a", "cat": "Math", "example": "" },
  "sin": { "syntax": "sin r? a", "desc": "r? = sin(a) (rad)", "cat": "Trig", "example": "" },
  "cos": { "syntax": "cos r? a", "desc": "r? = cos(a) (rad)", "cat": "Trig", "example": "" },
  "tan": { "syntax": "tan r? a", "desc": "r? = tan(a) (rad)", "cat": "Trig", "example": "" },
  "asin": { "syntax": "asin r? a", "desc": "r? = arcsin(a)", "cat": "Trig", "example": "" },
  "acos": { "syntax": "acos r? a", "desc": "r? = arccos(a)", "cat": "Trig", "example": "" },
  "atan": { "syntax": "atan r? a", "desc": "r? = arctan(a)", "cat": "Trig", "example": "" },
  "atan2": { "syntax": "atan2 r? a b", "desc": "r? = atan2(a,b)", "cat": "Trig", "example": "" },
  "deg2rad": { "syntax": "deg2rad r? a", "desc": "r? = degrees to radians", "cat": "Trig", "example": "deg2rad r0 180" },
  "rad2deg": { "syntax": "rad2deg r? a", "desc": "r? = radians to degrees", "cat": "Trig", "example": "rad2deg r0 3.14159" },
  "and": { "syntax": "and r? a b", "desc": "r? = a AND b (bitwise)", "cat": "Bitwise", "example": "" },
  "or": { "syntax": "or r? a b", "desc": "r? = a OR b (bitwise)", "cat": "Bitwise", "example": "" },
  "xor": { "syntax": "xor r? a b", "desc": "r? = a XOR b (bitwise)", "cat": "Bitwise", "example": "" },
  "nor": { "syntax": "nor r? a b", "desc": "r? = a NOR b (bitwise)", "cat": "Bitwise", "example": "" },
  "sll": { "syntax": "sll r? a b", "desc": "r? = a << b (shift left)", "cat": "Bitwise", "example": "" },
  "sla": { "syntax": "sla r? a b", "desc": "r? = a << b (arith)", "cat": "Bitwise", "example": "" },
  "srl": { "syntax": "srl r? a b", "desc": "r? = a >> b (shift right)", "cat": "Bitwise", "example": "" },
  "sra": { "syntax": "sra r? a b", "desc": "r? = a >> b (arith)", "cat": "Bitwise", "example": "" },
  "seq": { "syntax": "seq r? a b", "desc": "r? = 1 if a == b else 0", "cat": "Compare", "example": "seq r0 r1 r2" },
  "seqz": { "syntax": "seqz r? a", "desc": "r? = 1 if a == 0 else 0", "cat": "Compare", "example": "seqz r0 r1" },
  "sne": { "syntax": "sne r? a b", "desc": "r? = 1 if a != b else 0", "cat": "Compare", "example": "" },
  "snez": { "syntax": "snez r? a", "desc": "r? = 1 if a != 0 else 0", "cat": "Compare", "example": "" },
  "sge": { "syntax": "sge r? a b", "desc": "r? = 1 if a >= b else 0", "cat": "Compare", "example": "" },
  "sgez": { "syntax": "sgez r? a", "desc": "r? = 1 if a >= 0 else 0", "cat": "Compare", "example": "" },
  "sgt": { "syntax": "sgt r? a b", "desc": "r? = 1 if a > b else 0", "cat": "Compare", "example": "sgt r2 r0 r1" },
  "sgtz": { "syntax": "sgtz r? a", "desc": "r? = 1 if a > 0 else 0", "cat": "Compare", "example": "" },
  "sle": { "syntax": "sle r? a b", "desc": "r? = 1 if a <= b else 0", "cat": "Compare", "example": "" },
  "slez": { "syntax": "slez r? a", "desc": "r? = 1 if a <= 0 else 0", "cat": "Compare", "example": "" },
  "slt": { "syntax": "slt r? a b", "desc": "r? = 1 if a < b else 0", "cat": "Compare", "example": "slt r2 r0 r1" },
  "sltz": { "syntax": "sltz r? a", "desc": "r? = 1 if a < 0 else 0", "cat": "Compare", "example": "" },
  "sap": { "syntax": "sap r? a b", "desc": "r? = 1 if a ~= b (~0.005)", "cat": "Compare", "example": "" },
  "sapz": { "syntax": "sapz r? a", "desc": "r? = 1 if a ~= 0", "cat": "Compare", "example": "" },
  "sna": { "syntax": "sna r? a b", "desc": "r? = 1 if a NOT ~= b", "cat": "Compare", "example": "" },
  "snan": { "syntax": "snan r? a", "desc": "r? = 1 if a is NaN", "cat": "Compare", "example": "" },
  "snaz": { "syntax": "snaz r? a", "desc": "r? = 1 if a NOT ~= 0", "cat": "Compare", "example": "" },
  "sdns": { "syntax": "sdns r? d? logicType", "desc": "r? = 1 if device d? has NOT set this logicType (disconnected)", "cat": "Device Check", "example": "" },
  "sdse": { "syntax": "sdse r? d? logicType", "desc": "r? = 1 if device d? HAS set this logicType", "cat": "Device Check", "example": "" },
  "j": { "syntax": "j label", "desc": "Jump to label (unconditional)", "cat": "Branch", "example": "j start" },
  "jal": { "syntax": "jal label", "desc": "Jump to label, store return in ra", "cat": "Branch", "example": "jal myFunc" },
  "jr": { "syntax": "jr (r?|num)", "desc": "Jump relative (+/- lines)", "cat": "Branch", "example": "jr -5" },
  "return": { "syntax": "return", "desc": "Return to ra (after jal)", "cat": "Branch", "example": "return" },
  "beq": { "syntax": "beq a b label", "desc": "Branch if a == b", "cat": "Branch", "example": "beq r0 1 turnOn" },
  "beqz": { "syntax": "beqz a label", "desc": "Branch if a == 0", "cat": "Branch", "example": "beqz r0 done" },
  "bne": { "syntax": "bne a b label", "desc": "Branch if a != b", "cat": "Branch", "example": "" },
  "bnez": { "syntax": "bnez a label", "desc": "Branch if a != 0", "cat": "Branch", "example": "bnez r0 loop" },
  "bge": { "syntax": "bge a b label", "desc": "Branch if a >= b", "cat": "Branch", "example": "" },
  "bgez": { "syntax": "bgez a label", "desc": "Branch if a >= 0", "cat": "Branch", "example": "" },
  "bgt": { "syntax": "bgt a b label", "desc": "Branch if a > b", "cat": "Branch", "example": "" },
  "bgtz": { "syntax": "bgtz a label", "desc": "Branch if a > 0", "cat": "Branch", "example": "" },
  "ble": { "syntax": "ble a b label", "desc": "Branch if a <= b", "cat": "Branch", "example": "" },
  "blez": { "syntax": "blez a label", "desc": "Branch if a <= 0", "cat": "Branch", "example": "" },
  "blt": { "syntax": "blt a b label", "desc": "Branch if a < b", "cat": "Branch", "example": "" },
  "bltz": { "syntax": "bltz a label", "desc": "Branch if a < 0", "cat": "Branch", "example": "" },
  "bap": { "syntax": "bap a b label", "desc": "Branch if a ~ b", "cat": "Branch", "example": "" },
  "bapz": { "syntax": "bapz a label", "desc": "Branch if a ~ 0", "cat": "Branch", "example": "" },
  "bna": { "syntax": "bna a b label", "desc": "Branch if a !~ b", "cat": "Branch", "example": "" },
  "bnan": { "syntax": "bnan a label", "desc": "Branch if a is NaN", "cat": "Branch", "example": "" },
  "bnaz": { "syntax": "bnaz a label", "desc": "Branch if a !~ 0", "cat": "Branch", "example": "" },
  "bdns": { "syntax": "bdns d? logicType label", "desc": "Branch if d? NOT set (disconnected)", "cat": "Branch", "example": "" },
  "bdse": { "syntax": "bdse d? logicType label", "desc": "Branch if d? IS set", "cat": "Branch", "example": "" },
  "push": { "syntax": "push r?", "desc": "Push register onto stack, sp++", "cat": "Stack", "example": "push r0" },
  "pop": { "syntax": "pop r?", "desc": "Pop stack into register, sp--", "cat": "Stack", "example": "pop r0" },
  "peek": { "syntax": "peek r?", "desc": "Read stack[sp-1] without changing sp", "cat": "Stack", "example": "peek r0" },
  "poke": { "syntax": "poke a v", "desc": "Store v at address a in stack", "cat": "Stack", "example": "" },
  "stack": { "syntax": "stack r? action", "desc": "0=push, 1=pop, 2=peek, 3=size", "cat": "Stack", "example": "" },
  "get": { "syntax": "get r? d? address", "desc": "Load from device's stack at address", "cat": "Stack (Ext)", "example": "" },
  "getd": { "syntax": "getd r? id address", "desc": "Load from device ID's stack at address", "cat": "Stack (Ext)", "example": "" },
  "put": { "syntax": "put d? address value", "desc": "Store value to device's stack", "cat": "Stack (Ext)", "example": "" },
  "putd": { "syntax": "putd id address value", "desc": "Store value to device ID's stack", "cat": "Stack (Ext)", "example": "" },
  "yield": { "syntax": "yield", "desc": "Pause 1 tick (0.5s). Prevents double-run per tick", "cat": "Control", "example": "yield" },
  "sleep": { "syntax": "sleep (r?|num)", "desc": "Sleep N ticks (1 tick = 0.5s)", "cat": "Control", "example": "sleep 10" },
  "hcf": { "syntax": "hcf", "desc": "Halt and Catch Fire – crashes the IC chip", "cat": "Control", "example": "" },
  "debug": { "syntax": "debug r?", "desc": "Output register to game console", "cat": "Control", "example": "debug r0" },
  "alias": { "syntax": "alias name r?|d?", "desc": "Name a register or device pin", "cat": "Preprocessor", "example": "alias Pressure r0\nalias Furnace d0" },
  "define": { "syntax": "define name value", "desc": "Compile-time constant", "cat": "Preprocessor", "example": "define MinTemp 100" },
  "select": { "syntax": "select r? value", "desc": "Compile-time device pin select", "cat": "Preprocessor", "example": "" }
}
